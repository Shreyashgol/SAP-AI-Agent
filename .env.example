# ─── Application ───────────────────────────────────────────────────────────────
APP_ENV=development                     # development | staging | production
APP_SECRET_KEY=change-me-in-production  # 64-char random string
DEBUG=true

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sap_ai_platform
POSTGRES_USER=platform_user
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://platform_user:change-me@postgres:5432/sap_ai_platform

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_SESSION_DB=1
REDIS_CACHE_DB=2

# ─── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ─── Claude API ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001
# IMPORTANT: no-training header applied to all calls — NFR-C05

# ─── LangSmith ─────────────────────────────────────────────────────────────────
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=sap-ai-platform-dev
LANGCHAIN_TRACING_V2=true

# ─── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=8
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Encryption (AES-256 for credential vault) ─────────────────────────────────
ENCRYPTION_KEY=change-me-32-byte-base64-key=====

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_USER=60        # requests/minute
RATE_LIMIT_PER_TENANT=100     # requests/minute

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Voyage AI (embeddings — Anthropic has no embeddings endpoint) ──
VOYAGE_API_KEY=your-voyage-api-key
