      { "column_number": 3,  "field": "DocStatus", "business_name": "Payment Status",               "description": "Status of the vendor payment.",                                 "type": "Char",     "length": 1,  "is_pk": false, "is_fk": false, "references": null, "enum_values": {"O":"Open","C":"Closed"} },
