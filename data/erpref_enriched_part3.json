      { "column_number": 7, "field": "BankCode",  "business_name": "Bank Code",            "description": "Bank where cheque is to be deposited.", "type": "nVarChar", "length": 5, "is_pk": false, "is_fk": false, "references": null }
    ]
  },
  {
