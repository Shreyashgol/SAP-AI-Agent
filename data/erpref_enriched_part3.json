[
  {
    "table_name": "OJDT",
    "business_name": "Journal Entry (GL Transaction)",
    "module": "Finance",
    "module_id": 5,
    "description": "Every financial posting in SAP B1 creates one row here. Master of all GL movements — AR invoices, AP invoices, payments, receipts, stock postings all trace back to OJDT.",
    "is_master": true, "is_header": true, "is_line": false,
    "total_columns": 35,
    "primary_key": { "columns": ["TransId"], "confidence": 0.95, "rule": "known_master_transid" },
    "joins": [
      { "to_table": "JDT1", "to_business_name": "Journal Entry Line Items (GL Postings)", "from_column": "TransId",  "to_column": "TransId",  "on_clause": "OJDT.TransId = JDT1.TransId",   "join_type": "LEFT", "purpose": "Get debit/credit lines and account codes for the GL entry", "confidence": 0.99 },
      { "to_table": "OINV", "to_business_name": "A/R Invoice",                             "from_column": "TransId",  "to_column": "TransId",  "on_clause": "OJDT.TransId = OINV.TransId",  "join_type": "LEFT", "purpose": "Find which sales invoice created this journal entry",      "confidence": 0.88 },
      { "to_table": "OPCH", "to_business_name": "A/P Invoice",                             "from_column": "TransId",  "to_column": "TransId",  "on_clause": "OJDT.TransId = OPCH.TransId",  "join_type": "LEFT", "purpose": "Find which purchase invoice created this journal entry",  "confidence": 0.88 }
    ],
    "columns": [
      { "column_number": 1,  "field": "TransId",     "business_name": "Journal Entry ID (Internal Key)", "description": "Unique internal ID. Referenced by all financial documents as FK.", "type": "Int",      "length": 11, "is_pk": true,  "is_fk": false, "references": null },
      { "column_number": 2,  "field": "BtfStatus",   "business_name": "Journal Entry Status",            "description": "Status of the journal entry.",                                   "type": "Char",     "length": 1,  "is_pk": false, "is_fk": false, "references": null, "enum_values": {"P":"Posted","D":"Draft","E":"Error"} },
      { "column_number": 3,  "field": "TransType",   "business_name": "Transaction Source Type",         "description": "Type of source document that created this entry.",               "type": "nVarChar", "length": 20, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 4,  "field": "BaseRef",     "business_name": "Source Document Number",          "description": "DocNum of the originating document (invoice, payment, etc.).",   "type": "nVarChar", "length": 11, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 5,  "field": "RefDate",     "business_name": "Posting Date",                    "description": "Date the GL posting was made — used for period reporting.",       "type": "Date",     "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 6,  "field": "DueDate",     "business_name": "Due Date",                        "description": "Due date for payment-related journal entries.",                  "type": "Date",     "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 7,  "field": "TaxDate",     "business_name": "Document Date",                   "description": "Date on the original source document.",                          "type": "Date",     "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 8,  "field": "Memo",        "business_name": "Journal Entry Narration",         "description": "Narration or description for this GL entry.",                    "type": "nVarChar", "length": 50, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 9,  "field": "Ref1",        "business_name": "Reference 1",                     "description": "First reference field — usually source document number.",        "type": "nVarChar", "length": 11, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 10, "field": "Ref2",        "business_name": "Reference 2",                     "description": "Second reference — often vendor/customer reference.",            "type": "nVarChar", "length": 11, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 11, "field": "Ref3",        "business_name": "Reference 3",                     "description": "Third reference field.",                                         "type": "nVarChar", "length": 11, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 12, "field": "CreatedBy",   "business_name": "Created By (User ID)",            "description": "User who posted this journal entry.",                            "type": "Int",      "length": 6,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 13, "field": "CreateDate",  "business_name": "Created Date",                    "description": "Date this journal entry was created.",                           "type": "Date",     "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 14, "field": "DocNum",      "business_name": "Journal Entry Number",            "description": "User-facing sequential journal entry number.",                   "type": "Int",      "length": 11, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 15, "field": "IsAutoGen",   "business_name": "System-Generated Flag",           "description": "Y if automatically created by the system (not manual entry).",   "type": "Char",     "length": 1,  "is_pk": false, "is_fk": false, "references": null, "enum_values": {"Y":"Auto-generated","N":"Manual"} }
    ]
  },
  {
    "table_name": "JDT1",
    "business_name": "Journal Entry Line Items (GL Debit / Credit Lines)",
    "module": "Finance",
    "module_id": 5,
    "description": "Each row is one debit or credit line on a journal entry. Every penny in SAP B1's ledger is stored here. Key table for GL reporting, trial balance, and P&L.",
    "is_master": false, "is_header": false, "is_line": true,
    "total_columns": 30,
    "primary_key": { "columns": ["TransId","Line_ID"], "confidence": 0.95, "rule": "line_table_composite" },
    "joins": [
      { "to_table": "OJDT", "to_business_name": "Journal Entry Header",     "from_column": "TransId",  "to_column": "TransId",  "on_clause": "JDT1.TransId = OJDT.TransId",   "join_type": "LEFT", "purpose": "Get journal entry narration, date, source type", "confidence": 0.99 },
      { "to_table": "OACT", "to_business_name": "Chart of Accounts",        "from_column": "Account",  "to_column": "AcctCode", "on_clause": "JDT1.Account = OACT.AcctCode",  "join_type": "LEFT", "purpose": "Get account name and account type for each GL line", "confidence": 0.95 },
      { "to_table": "OCRD", "to_business_name": "Business Partner (Debtor/Creditor)", "from_column": "ContraAct","to_column": "CardCode", "on_clause": "JDT1.ContraAct = OCRD.CardCode", "join_type": "LEFT", "purpose": "Get customer/vendor name for AP/AR control account lines", "confidence": 0.80 }
    ],
    "columns": [
      { "column_number": 1,  "field": "TransId",    "business_name": "Journal Entry ID",        "description": "FK to OJDT.TransId.",                                "type": "Int",      "length": 11, "is_pk": true,  "is_fk": true,  "references": {"table":"OJDT","business_name":"Journal Entry","column":"TransId","confidence":0.99} },
      { "column_number": 2,  "field": "Line_ID",    "business_name": "GL Line Number",          "description": "Sequential line number within the journal entry.",   "type": "Int",      "length": 6,  "is_pk": true,  "is_fk": false, "references": null },
      { "column_number": 3,  "field": "Account",    "business_name": "GL Account Code",         "description": "General ledger account code. FK to OACT.AcctCode.", "type": "nVarChar", "length": 15, "is_pk": false, "is_fk": true,  "references": {"table":"OACT","business_name":"Chart of Accounts","column":"AcctCode","confidence":0.95} },
      { "column_number": 4,  "field": "Debit",      "business_name": "Debit Amount",            "description": "Debit amount for this GL line (zero if credit line).", "type": "Sum",     "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 5,  "field": "Credit",     "business_name": "Credit Amount",           "description": "Credit amount for this GL line (zero if debit line).", "type": "Sum",    "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 6,  "field": "SYSDeb",     "business_name": "Debit in Local Currency", "description": "Debit in system base currency.",                     "type": "Sum",      "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 7,  "field": "SYSCred",    "business_name": "Credit in Local Currency","description": "Credit in system base currency.",                    "type": "Sum",      "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 8,  "field": "FCDebit",    "business_name": "Debit in Foreign Currency","description": "Debit in foreign currency (for FC transactions).",  "type": "Sum",      "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 9,  "field": "FCCredit",   "business_name": "Credit in Foreign Currency","description": "Credit in foreign currency.",                      "type": "Sum",      "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 10, "field": "ContraAct",  "business_name": "Business Partner / Contra Account", "description": "CardCode or account for contra side. FK to OCRD.", "type": "nVarChar", "length": 15, "is_pk": false, "is_fk": true, "references": {"table":"OCRD","business_name":"Business Partner","column":"CardCode","confidence":0.80} },
      { "column_number": 11, "field": "ShortName",  "business_name": "Short Name (Card / Account)", "description": "Short name of the business partner or account.",  "type": "nVarChar", "length": 15, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 12, "field": "Ref1",       "business_name": "Reference 1",             "description": "Reference field on the GL line.",                   "type": "nVarChar", "length": 11, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 13, "field": "Ref2",       "business_name": "Reference 2",             "description": "Second reference on the GL line.",                  "type": "nVarChar", "length": 11, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 14, "field": "LineMemo",   "business_name": "Line Narration",          "description": "Narration specific to this debit/credit line.",      "type": "nVarChar", "length": 50, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 15, "field": "PrcCode",    "business_name": "Cost Centre / Profit Centre", "description": "FK to OPRC — profit centre for this GL line.", "type": "nVarChar", "length": 8,  "is_pk": false, "is_fk": true,  "references": {"table":"OPRC","business_name":"Profit Centre","column":"PrcCode","confidence":0.82} }
    ]
  },
  {
    "table_name": "ORCT",
    "business_name": "Incoming Payment (Customer Receipt)",
    "module": "Finance",
    "module_id": 5,
    "description": "Records payments received from customers. Can be matched against one or more A/R invoices. Payment modes include cash, cheque, bank transfer.",
    "is_master": true, "is_header": true, "is_line": false,
    "total_columns": 40,
    "primary_key": { "columns": ["DocEntry"], "confidence": 0.90, "rule": "document_header" },
    "joins": [
      { "to_table": "RCT1", "to_business_name": "Incoming Payment Invoice Allocation",  "from_column": "DocEntry", "to_column": "DocEntry", "on_clause": "ORCT.DocEntry = RCT1.DocEntry", "join_type": "LEFT", "purpose": "Get which invoices this receipt is settled against",  "confidence": 0.99 },
      { "to_table": "RCT2", "to_business_name": "Incoming Payment Cheque Details",      "from_column": "DocEntry", "to_column": "DocEntry", "on_clause": "ORCT.DocEntry = RCT2.DocEntry", "join_type": "LEFT", "purpose": "Get cheque number, bank, date for cheque receipts",   "confidence": 0.99 },
      { "to_table": "OCRD", "to_business_name": "Business Partner (Customer)",          "from_column": "CardCode", "to_column": "CardCode", "on_clause": "ORCT.CardCode = OCRD.CardCode",  "join_type": "LEFT", "purpose": "Get customer name and account details",              "confidence": 0.95 },
      { "to_table": "OJDT", "to_business_name": "Journal Entry",                        "from_column": "TransId",  "to_column": "TransId",  "on_clause": "ORCT.TransId = OJDT.TransId",   "join_type": "LEFT", "purpose": "Get GL posting created when payment was received",  "confidence": 0.90 }
    ],
    "columns": [
      { "column_number": 1,  "field": "DocEntry",   "business_name": "Receipt Internal ID",          "description": "Unique system key. FK target in RCT1, RCT2.",                  "type": "Int",      "length": 11, "is_pk": true,  "is_fk": false, "references": null },
      { "column_number": 2,  "field": "DocNum",     "business_name": "Receipt Number",               "description": "User-facing sequential receipt number.",                        "type": "Int",      "length": 11, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 3,  "field": "DocStatus",  "business_name": "Receipt Status",               "description": "Status of the receipt.",                                       "type": "Char",     "length": 1,  "is_pk": false, "is_fk": false, "references": null, "enum_values": {"O":"Open","C":"Closed"} },
      { "column_number": 4,  "field": "CardCode",   "business_name": "Customer Code",                "description": "Customer who made the payment. FK to OCRD.",                    "type": "nVarChar", "length": 15, "is_pk": false, "is_fk": true,  "references": {"table":"OCRD","business_name":"Business Partner (Customer)","column":"CardCode","confidence":0.95} },
      { "column_number": 5,  "field": "CardName",   "business_name": "Customer Name",                "description": "Customer name at time of receipt.",                             "type": "nVarChar", "length": 100,"is_pk": false, "is_fk": false, "references": null },
      { "column_number": 6,  "field": "DocDate",    "business_name": "Payment Receipt Date",         "description": "Date payment was received.",                                    "type": "Date",     "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 7,  "field": "DocTotal",   "business_name": "Total Amount Received",        "description": "Total amount received from customer.",                          "type": "Sum",      "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 8,  "field": "NoDocSum",   "business_name": "Unallocated / On-Account Amount","description": "Amount received but not yet matched to any invoice.",          "type": "Sum",      "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 9,  "field": "CashSum",    "business_name": "Cash Received",                "description": "Portion of payment received in cash.",                          "type": "Sum",      "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 10, "field": "CheckSum",   "business_name": "Cheque Amount Received",       "description": "Portion received by cheque.",                                   "type": "Sum",      "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 11, "field": "TrsfrSum",   "business_name": "Bank Transfer Amount Received","description": "Portion received via bank transfer / NEFT / RTGS.",             "type": "Sum",      "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 12, "field": "DocCur",     "business_name": "Payment Currency",             "description": "Currency in which payment was received.",                       "type": "nVarChar", "length": 3,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 13, "field": "TransId",    "business_name": "Journal Entry ID",             "description": "FK to OJDT.TransId — GL posting for this receipt.",             "type": "Int",      "length": 11, "is_pk": false, "is_fk": true,  "references": {"table":"OJDT","business_name":"Journal Entry","column":"TransId","confidence":0.90} },
      { "column_number": 14, "field": "Comments",   "business_name": "Remarks",                      "description": "Free-text notes on this receipt.",                              "type": "nVarChar", "length": 254,"is_pk": false, "is_fk": false, "references": null }
    ]
  },
  {
    "table_name": "RCT1",
    "business_name": "Incoming Payment Invoice Allocation (Receipt-to-Invoice Matching)",
    "module": "Finance",
    "module_id": 5,
    "description": "Links each incoming payment to the specific invoices it settles. Enables AR reconciliation and outstanding balance tracking.",
    "is_master": false, "is_header": false, "is_line": true,
    "total_columns": 12,
    "primary_key": { "columns": ["DocEntry","InvType","DocNum"], "confidence": 0.90, "rule": "line_table_composite" },
    "joins": [
      { "to_table": "ORCT", "to_business_name": "Incoming Payment",  "from_column": "DocEntry",  "to_column": "DocEntry",  "on_clause": "RCT1.DocEntry = ORCT.DocEntry",  "join_type": "LEFT", "purpose": "Get the receipt this allocation belongs to",   "confidence": 0.99 },
      { "to_table": "OINV", "to_business_name": "A/R Invoice",       "from_column": "DocNum",    "to_column": "DocNum",    "on_clause": "RCT1.DocNum = OINV.DocNum",       "join_type": "LEFT", "purpose": "Get the invoice being settled by this receipt","confidence": 0.85 }
    ],
    "columns": [
      { "column_number": 1, "field": "DocEntry",  "business_name": "Receipt Internal ID",        "description": "FK to ORCT.DocEntry.", "type": "Int",      "length": 11, "is_pk": true,  "is_fk": true,  "references": {"table":"ORCT","business_name":"Incoming Payment","column":"DocEntry","confidence":0.99} },
      { "column_number": 2, "field": "InvType",   "business_name": "Invoice Document Type",      "description": "Type code of the matched invoice (e.g. 13=AR Invoice).", "type": "Int", "length": 6, "is_pk": true, "is_fk": false, "references": null },
      { "column_number": 3, "field": "DocNum",    "business_name": "Invoice Number",             "description": "DocNum of the invoice being settled.", "type": "Int",      "length": 11, "is_pk": true,  "is_fk": true,  "references": {"table":"OINV","business_name":"A/R Invoice","column":"DocNum","confidence":0.85} },
      { "column_number": 4, "field": "SumApplied","business_name": "Amount Applied to Invoice",  "description": "How much of the receipt is applied to this invoice.", "type": "Sum", "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 5, "field": "ApplDate",  "business_name": "Application Date",          "description": "Date this receipt was matched to the invoice.", "type": "Date", "length": 0, "is_pk": false, "is_fk": false, "references": null }
    ]
  },
  {
    "table_name": "RCT2",
