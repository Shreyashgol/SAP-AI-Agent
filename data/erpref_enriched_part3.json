      { "column_number": 2, "field": "LineNum",   "business_name": "Cheque Line Number",   "description": "Sequence for multiple cheques in one receipt.", "type": "Int", "length": 6, "is_pk": true, "is_fk": false, "references": null },
      { "column_number": 3, "field": "CheckAcc",  "business_name": "Bank Account",         "description": "Bank account cheque is drawn on.", "type": "nVarChar", "length": 15, "is_pk": false, "is_fk": false, "references": null },
