      { "column_number": 11, "field": "statusCode",  "business_name": "Employment Status Code",       "description": "Current employment status.", "type": "Char", "length": 1, "is_pk": false, "is_fk": false, "references": null, "enum_values": {"A":"Active","T":"Terminated","L":"On Leave","R":"Retired"} },
      { "column_number": 12, "field": "salary",      "business_name": "Monthly Salary",               "description": "Employee's current monthly salary.", "type": "Sum",      "length": 19, "is_pk": false, "is_fk": false, "references": null },
