      { "column_number": 16, "field": "manager",     "business_name": "Reporting Manager Employee ID","description": "empID of the line manager. FK to OHEM (self-join).", "type": "Int",      "length": 11, "is_pk": false, "is_fk": true,  "references": {"table":"OHEM","business_name":"Employee Master","column":"empID","confidence":0.85} }
    ]
