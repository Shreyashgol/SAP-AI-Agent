      { "column_number": 8,  "field": "DocTotal",   "business_name": "GRN Total Value",            "description": "Total value of goods received.",                          "type": "Sum",      "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 9,  "field": "VatSum",     "business_name": "Input GST on GRN",           "description": "Total GST input credit on this goods receipt.",            "type": "Sum",      "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 10, "field": "SlpCode",    "business_name": "Buyer Code",                 "description": "FK to OSLP.",                                             "type": "Int",      "length": 6,  "is_pk": false, "is_fk": true,  "references": {"table":"OSLP","business_name":"Sales Employee","column":"SlpCode","confidence":0.88} },
