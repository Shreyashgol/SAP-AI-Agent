[
  {
    "table_name": "OPCH",
    "business_name": "Purchase Invoice (A/P Invoice)",
    "module": "Purchasing",
    "module_id": 4,
    "description": "Header for all vendor/supplier invoices. Each row is one A/P invoice. Line items stored in PCH1. Creates a payable liability in the GL.",
    "is_master": true,
    "is_header": true,
    "is_line": false,
    "total_columns": 50,
    "primary_key": { "columns": ["DocEntry"], "confidence": 0.90, "rule": "document_header" },
    "joins": [
      { "to_table": "PCH1", "to_business_name": "Purchase Invoice Line Items",     "from_column": "DocEntry", "to_column": "DocEntry", "on_clause": "OPCH.DocEntry = PCH1.DocEntry", "join_type": "LEFT", "purpose": "Get all line items — products received, quantities, costs",              "confidence": 0.99 },
      { "to_table": "OCRD", "to_business_name": "Business Partner (Vendor)",       "from_column": "CardCode", "to_column": "CardCode", "on_clause": "OPCH.CardCode = OCRD.CardCode",  "join_type": "LEFT", "purpose": "Get vendor name, payment terms, bank details",                        "confidence": 0.95 },
      { "to_table": "PCH3", "to_business_name": "Purchase Invoice WHT / TDS Lines","from_column": "DocEntry", "to_column": "DocEntry", "on_clause": "OPCH.DocEntry = PCH3.DocEntry", "join_type": "LEFT", "purpose": "Get TDS deducted on this vendor invoice",                             "confidence": 0.99 },
      { "to_table": "PCH2", "to_business_name": "Purchase Invoice Freight Lines",  "from_column": "DocEntry", "to_column": "DocEntry", "on_clause": "OPCH.DocEntry = PCH2.DocEntry", "join_type": "LEFT", "purpose": "Get freight and additional charges on this purchase invoice",         "confidence": 0.99 },
      { "to_table": "OJDT", "to_business_name": "Journal Entry",                   "from_column": "TransId",  "to_column": "TransId",  "on_clause": "OPCH.TransId = OJDT.TransId",   "join_type": "LEFT", "purpose": "Get GL posting created when invoice was posted",                     "confidence": 0.90 },
      { "to_table": "OSLP", "to_business_name": "Sales Employee",                  "from_column": "SlpCode",  "to_column": "SlpCode",  "on_clause": "OPCH.SlpCode = OSLP.SlpCode",   "join_type": "LEFT", "purpose": "Get buyer / purchase officer responsible for this invoice",          "confidence": 0.88 }
    ],
    "columns": [
      { "column_number": 1,  "field": "DocEntry",    "business_name": "Internal Invoice ID (System Key)",       "description": "Unique system-generated key. FK target in PCH1, PCH2, PCH3.",    "type": "Int",      "length": 11, "is_pk": true,  "is_fk": false, "references": null },
      { "column_number": 2,  "field": "DocNum",      "business_name": "Vendor Invoice Number (User-Facing)",    "description": "Sequential user-facing purchase invoice number.",                 "type": "Int",      "length": 11, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 3,  "field": "DocType",     "business_name": "Document Type",                          "description": "I=Item-based, S=Service-based purchase invoice.",                "type": "Char",     "length": 1,  "is_pk": false, "is_fk": false, "references": null, "enum_values": {"I":"Item Invoice","S":"Service Invoice"} },
      { "column_number": 4,  "field": "DocStatus",   "business_name": "Invoice Status",                         "description": "Current status of the purchase invoice.",                       "type": "Char",     "length": 1,  "is_pk": false, "is_fk": false, "references": null, "enum_values": {"O":"Open","C":"Closed","D":"Draft"} },
      { "column_number": 5,  "field": "Cancelled",   "business_name": "Cancelled Flag",                         "description": "Y if this invoice has been cancelled.",                          "type": "Char",     "length": 1,  "is_pk": false, "is_fk": false, "references": null, "enum_values": {"Y":"Cancelled","N":"Active"} },
      { "column_number": 6,  "field": "CardCode",    "business_name": "Vendor Code",                            "description": "Supplier/vendor account code. FK to OCRD.",                     "type": "nVarChar", "length": 15, "is_pk": false, "is_fk": true,  "references": {"table":"OCRD","business_name":"Business Partner (Vendor)","column":"CardCode","confidence":0.95} },
      { "column_number": 7,  "field": "CardName",    "business_name": "Vendor Name",                            "description": "Vendor name copied from OCRD at posting time.",                  "type": "nVarChar", "length": 100,"is_pk": false, "is_fk": false, "references": null },
      { "column_number": 8,  "field": "DocDate",     "business_name": "Invoice Date",                           "description": "Date the vendor invoice was entered.",                          "type": "Date",     "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 9,  "field": "DocDueDate",  "business_name": "Payment Due Date",                       "description": "Date payment is due to the vendor.",                            "type": "Date",     "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 10, "field": "TaxDate",     "business_name": "Tax / GST Date",                         "description": "Date used for GST input credit reporting.",                     "type": "Date",     "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 11, "field": "NumAtCard",   "business_name": "Vendor's Invoice Reference Number",      "description": "Vendor's own invoice number (for reconciliation).",               "type": "nVarChar", "length": 26, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 12, "field": "DocTotal",    "business_name": "Invoice Total (Including Tax)",          "description": "Total payable amount including GST.",                           "type": "Sum",      "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 13, "field": "DocTotalFc",  "business_name": "Invoice Total in Foreign Currency",      "description": "Total in vendor's foreign currency if applicable.",              "type": "Sum",      "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 14, "field": "VatSum",      "business_name": "GST / Input Tax Amount",                 "description": "Total GST input credit on this purchase invoice.",               "type": "Sum",      "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 15, "field": "DiscSum",     "business_name": "Discount Amount",                        "description": "Total discount received from vendor.",                          "type": "Sum",      "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 16, "field": "PaidToDate",  "business_name": "Amount Paid to Vendor",                  "description": "Total amount paid against this invoice so far.",                 "type": "Sum",      "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 17, "field": "OpenSum",     "business_name": "Outstanding Payable Amount",             "description": "Remaining unpaid balance. Drives AP aging reports.",            "type": "Sum",      "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 18, "field": "DocCur",      "business_name": "Invoice Currency",                       "description": "Currency in which vendor invoiced.",                            "type": "nVarChar", "length": 3,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 19, "field": "DocRate",     "business_name": "Exchange Rate",                          "description": "Rate between invoice currency and system currency.",            "type": "Rate",     "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 20, "field": "SlpCode",     "business_name": "Buyer / Purchase Officer Code",          "description": "FK to OSLP — person who raised/approved the invoice.",         "type": "Int",      "length": 6,  "is_pk": false, "is_fk": true,  "references": {"table":"OSLP","business_name":"Sales Employee","column":"SlpCode","confidence":0.88} },
      { "column_number": 21, "field": "PrjCode",     "business_name": "Project Code",                           "description": "Project this purchase is linked to. FK to OPRJ.",             "type": "nVarChar", "length": 8,  "is_pk": false, "is_fk": true,  "references": {"table":"OPRJ","business_name":"Project","column":"PrjCode","confidence":0.85} },
      { "column_number": 22, "field": "OcrCode",     "business_name": "Cost Centre",                            "description": "Distribution rule / cost centre. FK to OOCR.",               "type": "nVarChar", "length": 8,  "is_pk": false, "is_fk": true,  "references": {"table":"OOCR","business_name":"Distribution Rule","column":"OcrCode","confidence":0.78} },
      { "column_number": 23, "field": "TransId",     "business_name": "Journal Entry ID",                       "description": "Linked journal entry in OJDT. FK to OJDT.TransId.",          "type": "Int",      "length": 11, "is_pk": false, "is_fk": true,  "references": {"table":"OJDT","business_name":"Journal Entry","column":"TransId","confidence":0.90} },
      { "column_number": 24, "field": "PymntGroup",  "business_name": "Payment Terms",                          "description": "Vendor payment terms group.",                                "type": "nVarChar", "length": 20, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 25, "field": "Comments",    "business_name": "Remarks",                                "description": "Free-text remarks on this purchase invoice.",                 "type": "nVarChar", "length": 254,"is_pk": false, "is_fk": false, "references": null },
      { "column_number": 26, "field": "CreateDate",  "business_name": "Created Date",                           "description": "Date this record was created in the system.",               "type": "Date",     "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 27, "field": "UpdateDate",  "business_name": "Last Updated Date",                      "description": "Date this record was last modified.",                       "type": "Date",     "length": 0,  "is_pk": false, "is_fk": false, "references": null }
    ]
  },
  {
    "table_name": "PCH1",
