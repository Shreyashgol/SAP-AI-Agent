      { "column_number": 5,  "field": "CardName",   "business_name": "Vendor Name",                "description": "Vendor name at time of GRN creation.",                    "type": "nVarChar", "length": 100,"is_pk": false, "is_fk": false, "references": null },
      { "column_number": 6,  "field": "DocDate",    "business_name": "GRN / Receipt Date",         "description": "Date goods were physically received.",                    "type": "Date",     "length": 0,  "is_pk": false, "is_fk": false, "references": null },
