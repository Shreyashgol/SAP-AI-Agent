      { "to_table": "OPCH", "to_business_name": "Purchase Invoice Header", "from_column": "DocEntry", "to_column": "DocEntry", "on_clause": "PCH1.DocEntry = OPCH.DocEntry", "join_type": "LEFT", "purpose": "Get invoice header — vendor, date, totals",         "confidence": 0.99 },
      { "to_table": "OITM", "to_business_name": "Item Master Data",        "from_column": "ItemCode", "to_column": "ItemCode", "on_clause": "PCH1.ItemCode = OITM.ItemCode", "join_type": "LEFT", "purpose": "Get item name, group, unit of measure",            "confidence": 0.95 },
      { "to_table": "OWHS", "to_business_name": "Warehouse",               "from_column": "WhsCode",  "to_column": "WhsCode",  "on_clause": "PCH1.WhsCode = OWHS.WhsCode",   "join_type": "LEFT", "purpose": "Get warehouse where goods were received",           "confidence": 0.90 },
      { "to_table": "OACT", "to_business_name": "GL Account (Chart of Accounts)", "from_column": "AcctCode", "to_column": "AcctCode", "on_clause": "PCH1.AcctCode = OACT.AcctCode", "join_type": "LEFT", "purpose": "Get expense GL account for service lines",   "confidence": 0.90 }
    ],
    "columns": [
      { "column_number": 1,  "field": "DocEntry",   "business_name": "Purchase Invoice Internal ID", "description": "FK to OPCH.DocEntry.",                                          "type": "Int",      "length": 11, "is_pk": true,  "is_fk": true,  "references": {"table":"OPCH","business_name":"Purchase Invoice","column":"DocEntry","confidence":0.99} },
      { "column_number": 2,  "field": "LineNum",    "business_name": "Line Number",                  "description": "Sequential line number within the invoice.",                     "type": "Int",      "length": 6,  "is_pk": true,  "is_fk": false, "references": null },
      { "column_number": 3,  "field": "ItemCode",   "business_name": "Item / Product Code",          "description": "Item purchased on this line. FK to OITM.",                       "type": "nVarChar", "length": 20, "is_pk": false, "is_fk": true,  "references": {"table":"OITM","business_name":"Item Master","column":"ItemCode","confidence":0.95} },
      { "column_number": 4,  "field": "Dscription", "business_name": "Item Description",             "description": "Description of item/service purchased.",                          "type": "nVarChar", "length": 100,"is_pk": false, "is_fk": false, "references": null },
      { "column_number": 5,  "field": "Quantity",   "business_name": "Purchased Quantity",           "description": "Quantity purchased on this line.",                               "type": "Quantity", "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 6,  "field": "Price",      "business_name": "Unit Cost Price",              "description": "Purchase cost per unit (before tax).",                           "type": "Price",    "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 7,  "field": "DiscPrcnt",  "business_name": "Discount Percentage",          "description": "Line-level discount from vendor.",                               "type": "Rate",     "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 8,  "field": "LineTotal",  "business_name": "Line Total Cost (Before Tax)", "description": "Quantity × Price after discount, before GST.",                   "type": "Sum",      "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 9,  "field": "VatGroup",   "business_name": "GST / Tax Code",               "description": "Input GST tax code for this line.",                              "type": "nVarChar", "length": 8,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 10, "field": "VatSum",     "business_name": "Input GST Amount on Line",     "description": "GST input tax amount on this purchase line.",                    "type": "Sum",      "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 11, "field": "WhsCode",    "business_name": "Receiving Warehouse",          "description": "Warehouse where goods were received. FK to OWHS.",               "type": "nVarChar", "length": 8,  "is_pk": false, "is_fk": true,  "references": {"table":"OWHS","business_name":"Warehouse","column":"WhsCode","confidence":0.90} },
      { "column_number": 12, "field": "AcctCode",   "business_name": "Expense GL Account",           "description": "GL account for service/expense items. FK to OACT.",             "type": "nVarChar", "length": 15, "is_pk": false, "is_fk": true,  "references": {"table":"OACT","business_name":"Chart of Accounts","column":"AcctCode","confidence":0.90} },
      { "column_number": 13, "field": "BaseType",   "business_name": "Base Document Type",           "description": "Type of originating document (e.g. 20=GRN, 22=Purchase Order).", "type": "Int",      "length": 6,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 14, "field": "BaseEntry",  "business_name": "Base Document Internal ID",    "description": "DocEntry of the source GRN or purchase order.",                  "type": "Int",      "length": 11, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 15, "field": "BaseLine",   "business_name": "Base Document Line Number",    "description": "Line number in the originating document.",                       "type": "Int",      "length": 6,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 16, "field": "LineStatus", "business_name": "Line Status",                  "description": "Status of this purchase line.",                                 "type": "Char",     "length": 1,  "is_pk": false, "is_fk": false, "references": null, "enum_values": {"O":"Open","C":"Closed"} }
    ]
  },
