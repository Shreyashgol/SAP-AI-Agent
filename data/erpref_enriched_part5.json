[
  {
    "table_name": "OITM",
    "business_name": "Item Master Data (Products / Materials)",
    "module": "Inventory",
    "module_id": 3,
    "description": "Master record for every product, raw material, service, or asset managed in SAP B1. Referenced by virtually every sales, purchasing, and inventory document. Contains pricing, UOM, GL accounts, and warehouse details.",
    "is_master": true, "is_header": false, "is_line": false,
    "total_columns": 65,
    "primary_key": { "columns": ["ItemCode"], "confidence": 0.99, "rule": "known_master_pk" },
    "joins": [
      { "to_table": "OITW", "to_business_name": "Item Warehouse Stock",       "from_column": "ItemCode",  "to_column": "ItemCode",  "on_clause": "OITM.ItemCode = OITW.ItemCode",  "join_type": "LEFT", "purpose": "Get current stock levels per warehouse",         "confidence": 0.99 },
      { "to_table": "OITB", "to_business_name": "Item Group",                 "from_column": "ItmsGrpCod","to_column": "ItmsGrpCod","on_clause": "OITM.ItmsGrpCod = OITB.ItmsGrpCod","join_type": "LEFT","purpose": "Get item category / group name",               "confidence": 0.97 },
      { "to_table": "OWHS", "to_business_name": "Warehouse",                  "from_column": "DfltWH",    "to_column": "WhsCode",   "on_clause": "OITM.DfltWH = OWHS.WhsCode",    "join_type": "LEFT", "purpose": "Get default warehouse name for this item",       "confidence": 0.90 },
      { "to_table": "OUOM", "to_business_name": "Unit of Measure",            "from_column": "SalUnitMsr","to_column": "UomCode",   "on_clause": "OITM.SalUnitMsr = OUOM.UomCode","join_type": "LEFT", "purpose": "Get sales unit of measure name",                 "confidence": 0.88 },
      { "to_table": "OINM", "to_business_name": "Inventory Transactions (Audit Trail)", "from_column": "ItemCode", "to_column": "ItemCode", "on_clause": "OITM.ItemCode = OINM.ItemCode", "join_type": "LEFT", "purpose": "Get all stock movements for this item", "confidence": 0.92 }
    ],
    "columns": [
      { "column_number": 1,  "field": "ItemCode",    "business_name": "Item / Product Code",          "description": "Unique code for the item. PK and FK target across all transaction tables.", "type": "nVarChar", "length": 20, "is_pk": true,  "is_fk": false, "references": null },
      { "column_number": 2,  "field": "ItemName",    "business_name": "Item Description / Product Name","description": "Full name of the item.",                                                   "type": "nVarChar", "length": 100,"is_pk": false, "is_fk": false, "references": null },
      { "column_number": 3,  "field": "FrgnName",    "business_name": "Foreign / Alternate Name",     "description": "Alternative name or foreign language description.",                         "type": "nVarChar", "length": 100,"is_pk": false, "is_fk": false, "references": null },
      { "column_number": 4,  "field": "ItmsGrpCod",  "business_name": "Item Group Code",              "description": "Item category / group. FK to OITB.",                                        "type": "Int",      "length": 6,  "is_pk": false, "is_fk": true,  "references": {"table":"OITB","business_name":"Item Group","column":"ItmsGrpCod","confidence":0.97} },
      { "column_number": 5,  "field": "SalUnitMsr",  "business_name": "Sales Unit of Measure",        "description": "UOM used in sales documents. FK to OUOM.",                                   "type": "nVarChar", "length": 8,  "is_pk": false, "is_fk": true,  "references": {"table":"OUOM","business_name":"Unit of Measure","column":"UomCode","confidence":0.88} },
      { "column_number": 6,  "field": "PurUnitMsr",  "business_name": "Purchase Unit of Measure",     "description": "UOM used in purchasing documents.",                                          "type": "nVarChar", "length": 8,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 7,  "field": "DfltWH",      "business_name": "Default Warehouse",            "description": "Default warehouse for this item. FK to OWHS.",                               "type": "nVarChar", "length": 8,  "is_pk": false, "is_fk": true,  "references": {"table":"OWHS","business_name":"Warehouse","column":"WhsCode","confidence":0.90} },
      { "column_number": 8,  "field": "OnHand",      "business_name": "Total Stock On Hand",          "description": "Total quantity in stock across all warehouses.",                              "type": "Quantity", "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 9,  "field": "IsCommited",  "business_name": "Committed / Reserved Quantity","description": "Quantity allocated to open sales orders or production orders.",               "type": "Quantity", "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 10, "field": "OnOrder",     "business_name": "On Purchase Order Quantity",   "description": "Quantity on open purchase orders — expected inbound.",                        "type": "Quantity", "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 11, "field": "MinLevel",    "business_name": "Minimum Stock Level",          "description": "Reorder point — triggers purchase recommendation when OnHand drops below.", "type": "Quantity", "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 12, "field": "MaxLevel",    "business_name": "Maximum Stock Level",          "description": "Maximum stock to hold — used in replenishment planning.",                   "type": "Quantity", "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 13, "field": "AvgPrice",    "business_name": "Average Cost / Moving Average","description": "Moving average cost price per unit (SAP B1 valuation method).",            "type": "Price",    "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 14, "field": "LastPurPrc",  "business_name": "Last Purchase Price",          "description": "Price at which item was last purchased.",                                    "type": "Price",    "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 15, "field": "LastSalPrc",  "business_name": "Last Sale Price",              "description": "Price at which item was last sold.",                                         "type": "Price",    "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 16, "field": "PrchseItem",  "business_name": "Is Purchased Item",           "description": "Y if this item can be purchased from vendors.",                               "type": "Char",     "length": 1,  "is_pk": false, "is_fk": false, "references": null, "enum_values": {"Y":"Yes","N":"No"} },
      { "column_number": 17, "field": "SellItem",    "business_name": "Is Sold Item",                "description": "Y if this item can be sold to customers.",                                   "type": "Char",     "length": 1,  "is_pk": false, "is_fk": false, "references": null, "enum_values": {"Y":"Yes","N":"No"} },
      { "column_number": 18, "field": "InvntItem",   "business_name": "Is Inventory Item",           "description": "Y if stock levels are tracked for this item.",                               "type": "Char",     "length": 1,  "is_pk": false, "is_fk": false, "references": null, "enum_values": {"Y":"Yes","N":"No"} },
      { "column_number": 19, "field": "ItemType",    "business_name": "Item Type",                   "description": "Classification of the item.",                                                "type": "Char",     "length": 1,  "is_pk": false, "is_fk": false, "references": null, "enum_values": {"I":"Item","S":"Service","R":"Resource","F":"Fixed Asset","T":"Travel"} },
      { "column_number": 20, "field": "Canceled",    "business_name": "Item Cancelled / Discontinued","description": "Y if this item has been discontinued.",                                      "type": "Char",     "length": 1,  "is_pk": false, "is_fk": false, "references": null, "enum_values": {"Y":"Discontinued","N":"Active"} }
    ]
