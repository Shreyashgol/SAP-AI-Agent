  {
    "table_name": "OITW",
    "business_name": "Item Warehouse Stock (Inventory Levels per Warehouse)",
    "module": "Inventory",
    "module_id": 3,
    "description": "Stocks levels per item per warehouse. One row for each item-warehouse combination. The primary source for inventory availability reporting.",
    "is_master": true, "is_header": false, "is_line": false,
    "total_columns": 20,
    "primary_key": { "columns": ["ItemCode","WhsCode"], "confidence": 0.97, "rule": "known_master_pk" },
    "joins": [
      { "to_table": "OITM", "to_business_name": "Item Master Data", "from_column": "ItemCode", "to_column": "ItemCode", "on_clause": "OITW.ItemCode = OITM.ItemCode", "join_type": "LEFT", "purpose": "Get item name, group, UOM, and pricing",              "confidence": 0.99 },
      { "to_table": "OWHS", "to_business_name": "Warehouse",        "from_column": "WhsCode",  "to_column": "WhsCode",  "on_clause": "OITW.WhsCode = OWHS.WhsCode",   "join_type": "LEFT", "purpose": "Get warehouse name and location for this stock",     "confidence": 0.99 }
    ],
    "columns": [
      { "column_number": 1,  "field": "ItemCode",   "business_name": "Item / Product Code",        "description": "FK to OITM. Composite PK with WhsCode.", "type": "nVarChar", "length": 20, "is_pk": true,  "is_fk": true,  "references": {"table":"OITM","business_name":"Item Master","column":"ItemCode","confidence":0.99} },
      { "column_number": 2,  "field": "WhsCode",    "business_name": "Warehouse Code",             "description": "FK to OWHS. Composite PK with ItemCode.", "type": "nVarChar", "length": 8,  "is_pk": true,  "is_fk": true,  "references": {"table":"OWHS","business_name":"Warehouse","column":"WhsCode","confidence":0.99} },
      { "column_number": 3,  "field": "OnHand",     "business_name": "Stock On Hand",             "description": "Current quantity physically in this warehouse.", "type": "Quantity", "length": 0, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 4,  "field": "IsCommited", "business_name": "Committed Quantity",        "description": "Quantity reserved for open sales orders from this warehouse.", "type": "Quantity", "length": 0, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 5,  "field": "OnOrder",    "business_name": "On Purchase Order",         "description": "Quantity on open POs expected at this warehouse.", "type": "Quantity", "length": 0, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 6,  "field": "MinLevel",   "business_name": "Minimum Level",             "description": "Minimum stock to trigger replenishment at this warehouse.", "type": "Quantity", "length": 0, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 7,  "field": "MaxLevel",   "business_name": "Maximum Level",             "description": "Maximum stock to hold at this warehouse.", "type": "Quantity", "length": 0, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 8,  "field": "AvgPrice",   "business_name": "Average Cost at Warehouse", "description": "Warehouse-specific moving average cost.", "type": "Price", "length": 0, "is_pk": false, "is_fk": false, "references": null }
    ]
  },
