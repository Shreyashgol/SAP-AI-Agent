      { "to_table": "OCRD", "to_business_name": "Customer",         "from_column": "CardCode",  "to_column": "CardCode",  "on_clause": "OSRN.CardCode = OCRD.CardCode",  "join_type": "LEFT", "purpose": "Get the customer who currently owns this serialized unit",           "confidence": 0.90 }
    ],
    "columns": [
      { "column_number": 1,  "field": "ItemCode",    "business_name": "Item / Product Code",        "description": "FK to OITM.ItemCode. Composite PK with SysSerial.",                      "type": "nVarChar", "length": 20, "is_pk": true,  "is_fk": true,  "references": {"table":"OITM","business_name":"Item Master","column":"ItemCode","confidence":0.99} },
      { "column_number": 2,  "field": "SysSerial",   "business_name": "System Serial Number (Internal ID)","description": "System-generated internal serial number ID.",                    "type": "Int",      "length": 11, "is_pk": true,  "is_fk": false, "references": null },
      { "column_number": 3,  "field": "MnfSerial",   "business_name": "Manufacturer Serial Number", "description": "Serial number printed on the product by the manufacturer (e.g. IMEI).",  "type": "nVarChar", "length": 32, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 4,  "field": "InternalSN",  "business_name": "Internal Serial Number",     "description": "Company's own serial number assigned to this unit.",                     "type": "nVarChar", "length": 32, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 5,  "field": "CardCode",    "business_name": "Customer Code (Owner)",      "description": "Customer currently owning this unit. FK to OCRD.",                       "type": "nVarChar", "length": 15, "is_pk": false, "is_fk": true,  "references": {"table":"OCRD","business_name":"Business Partner","column":"CardCode","confidence":0.90} },
      { "column_number": 6,  "field": "InDate",      "business_name": "Date Received Into Stock",   "description": "Date this serial number entered the warehouse.",                         "type": "Date",     "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 7,  "field": "OutDate",     "business_name": "Date Delivered to Customer", "description": "Date this serialized unit was sold/delivered.",                          "type": "Date",     "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 8,  "field": "WhsCode",     "business_name": "Current Warehouse",          "description": "Warehouse where this unit currently resides. FK to OWHS.",              "type": "nVarChar", "length": 8,  "is_pk": false, "is_fk": true,  "references": {"table":"OWHS","business_name":"Warehouse","column":"WhsCode","confidence":0.88} },
      { "column_number": 9,  "field": "MnfDate",     "business_name": "Manufacture Date",           "description": "Date this unit was manufactured.",                                      "type": "Date",     "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 10, "field": "ExpDate",     "business_name": "Warranty Expiry Date",       "description": "Date the warranty on this unit expires.",                               "type": "Date",     "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 11, "field": "Status",      "business_name": "Serial Number Status",       "description": "Current status of this serial number.",                                 "type": "Char",     "length": 1,  "is_pk": false, "is_fk": false, "references": null, "enum_values": {"I":"In Stock","D":"Delivered","U":"Used","R":"Returned"} }
