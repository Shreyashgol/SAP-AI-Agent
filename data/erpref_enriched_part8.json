    "is_master": true, "is_header": false, "is_line": false,
    "total_columns": 20,
    "primary_key": { "columns": ["BPLId"], "confidence": 0.99, "rule": "known_master_pk" },
    "joins": [
      { "to_table": "OINV", "to_business_name": "A/R Invoice",    "from_column": "BPLId", "to_column": "BPLId", "on_clause": "OBPL.BPLId = OINV.BPLId", "join_type": "LEFT", "purpose": "Get all AR invoices filed under this GSTIN/branch",    "confidence": 0.90 },
      { "to_table": "OPCH", "to_business_name": "A/P Invoice",    "from_column": "BPLId", "to_column": "BPLId", "on_clause": "OBPL.BPLId = OPCH.BPLId", "join_type": "LEFT", "purpose": "Get all AP invoices under this GSTIN/branch",        "confidence": 0.90 }
    ],
    "columns": [
      { "column_number": 1,  "field": "BPLId",       "business_name": "Business Place ID",               "description": "Unique ID for each branch/business place. PK. FK in OINV, OPCH etc.",   "type": "Int",      "length": 11, "is_pk": true,  "is_fk": false, "references": null },
      { "column_number": 2,  "field": "BPLName",     "business_name": "Branch / Business Place Name",    "description": "Name of the branch or business unit (e.g. Mumbai Branch, Delhi HO).",   "type": "nVarChar", "length": 100,"is_pk": false, "is_fk": false, "references": null },
      { "column_number": 3,  "field": "Address",     "business_name": "Branch Address",                  "description": "Physical address of this business place.",                              "type": "nVarChar", "length": 254,"is_pk": false, "is_fk": false, "references": null },
      { "column_number": 4,  "field": "TaxIdNum",    "business_name": "GSTIN (GST Registration Number)",  "description": "15-digit GST Identification Number for this branch. Core field for all India GST filings.", "type": "nVarChar", "length": 32, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 5,  "field": "VATRegNum",   "business_name": "VAT / TIN Number",                "description": "Old VAT/TIN registration number (pre-GST).",                            "type": "nVarChar", "length": 32, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 6,  "field": "MainBPL",     "business_name": "Is Main / Head Office",           "description": "Y if this is the primary registered business place.",                   "type": "Char",     "length": 1,  "is_pk": false, "is_fk": false, "references": null, "enum_values": {"Y":"Head Office","N":"Branch"} },
      { "column_number": 7,  "field": "Disabled",    "business_name": "Is Disabled / Closed",            "description": "Y if this business place is no longer active.",                         "type": "Char",     "length": 1,  "is_pk": false, "is_fk": false, "references": null, "enum_values": {"Y":"Disabled","N":"Active"} },
      { "column_number": 8,  "field": "State",       "business_name": "State",                           "description": "State where this business place is registered.",                        "type": "nVarChar", "length": 3,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 9,  "field": "Nature",      "business_name": "Business Nature / Type",          "description": "Nature of business for GST registration.",                              "type": "nVarChar", "length": 50, "is_pk": false, "is_fk": false, "references": null }
    ]
  },
  {
