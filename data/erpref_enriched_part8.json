      { "to_table": "ODLN", "to_business_name": "Delivery Note",        "from_column": "DocEntry",  "to_column": "DocEntry",  "on_clause": "SRI1.DocEntry = ODLN.DocEntry",  "join_type": "LEFT", "purpose": "Get delivery note this serial was dispatched on",               "confidence": 0.88 }
