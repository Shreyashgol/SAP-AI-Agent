[
  {
    "table_name": "ITM1",
    "business_name": "Item Prices per Price List",
    "module": "Inventory",
    "module_id": 3,
    "description": "Stores the price of each item for each price list. One row per item-pricelist combination. This is the definitive source for selling prices — OITM only holds the last purchase price and last sale price, not the structured price list prices.",
    "is_master": true, "is_header": false, "is_line": false,
    "total_columns": 12,
    "primary_key": { "columns": ["ItemCode","PriceList"], "confidence": 0.97, "rule": "known_master_pk" },
    "joins": [
      { "to_table": "OITM", "to_business_name": "Item Master Data", "from_column": "ItemCode",  "to_column": "ItemCode", "on_clause": "ITM1.ItemCode = OITM.ItemCode",   "join_type": "LEFT", "purpose": "Get item name, group, and UOM for this price row",       "confidence": 0.99 },
      { "to_table": "OPLN", "to_business_name": "Price List",       "from_column": "PriceList", "to_column": "ListNum",  "on_clause": "ITM1.PriceList = OPLN.ListNum", "join_type": "LEFT", "purpose": "Get the price list name (Retail, Wholesale, Export etc.)", "confidence": 0.97 }
    ],
    "columns": [
      { "column_number": 1,  "field": "ItemCode",   "business_name": "Item / Product Code",          "description": "FK to OITM.ItemCode. Composite PK with PriceList.",                          "type": "nVarChar", "length": 20, "is_pk": true,  "is_fk": true,  "references": {"table":"OITM","business_name":"Item Master","column":"ItemCode","confidence":0.99} },
      { "column_number": 2,  "field": "PriceList",  "business_name": "Price List Number",            "description": "FK to OPLN.ListNum. Composite PK with ItemCode.",                            "type": "Int",      "length": 6,  "is_pk": true,  "is_fk": true,  "references": {"table":"OPLN","business_name":"Price List","column":"ListNum","confidence":0.97} },
      { "column_number": 3,  "field": "Price",      "business_name": "Item Price for This List",     "description": "Selling price of this item on this price list (before discount).",           "type": "Price",    "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 4,  "field": "Currency",   "business_name": "Price Currency",               "description": "Currency of this price (e.g. INR, USD).",                                   "type": "nVarChar", "length": 3,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 5,  "field": "PriceAfVAT", "business_name": "Price Including Tax",          "description": "Price inclusive of VAT/GST.",                                               "type": "Price",    "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 6,  "field": "UomEntry",   "business_name": "Unit of Measure",              "description": "UOM for which this price applies.",                                        "type": "Int",      "length": 11, "is_pk": false, "is_fk": true,  "references": {"table":"OUOM","business_name":"Unit of Measure","column":"UomCode","confidence":0.85} },
      { "column_number": 7,  "field": "Factor",     "business_name": "Price Factor",                 "description": "Multiplier applied when this price derives from a base list.",               "type": "Rate",     "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 8,  "field": "AutoUpdate", "business_name": "Auto-Update Flag",             "description": "Y = price auto-updates when base price list changes.",                      "type": "Char",     "length": 1,  "is_pk": false, "is_fk": false, "references": null, "enum_values": {"Y":"Auto-update on","N":"Manual price"} }
    ]
  },
  {
    "table_name": "INV4",
    "business_name": "A/R Invoice Tax Lines (GST Breakdown per Invoice)",
    "module": "Sales",
    "module_id": 1,
    "description": "Stores the detailed tax (GST) breakdown for each A/R invoice — CGST, SGST, IGST, CESS amounts per tax code. Essential for GSTR-1, GSTR-3B and all GST return filing in India. One row per tax code per invoice.",
    "is_master": false, "is_header": false, "is_line": true,
    "total_columns": 15,
    "primary_key": { "columns": ["DocEntry","LineNum"], "confidence": 0.95, "rule": "line_table_composite" },
    "joins": [
      { "to_table": "OINV", "to_business_name": "A/R Invoice",        "from_column": "DocEntry",  "to_column": "DocEntry",  "on_clause": "INV4.DocEntry = OINV.DocEntry",  "join_type": "LEFT", "purpose": "Get invoice header — customer, date, total",               "confidence": 0.99 },
      { "to_table": "OSTC", "to_business_name": "Sales Tax Code",     "from_column": "StaCode",   "to_column": "Code",      "on_clause": "INV4.StaCode = OSTC.Code",       "join_type": "LEFT", "purpose": "Get GST code name and rate (CGST 9%, SGST 9%, IGST 18%)", "confidence": 0.92 }
    ],
    "columns": [
      { "column_number": 1,  "field": "DocEntry",   "business_name": "A/R Invoice Internal ID",    "description": "FK to OINV.DocEntry. Composite PK with LineNum.",                              "type": "Int",      "length": 11, "is_pk": true,  "is_fk": true,  "references": {"table":"OINV","business_name":"A/R Invoice","column":"DocEntry","confidence":0.99} },
      { "column_number": 2,  "field": "LineNum",    "business_name": "Tax Line Number",             "description": "Sequential line for each GST component on this invoice.",                     "type": "Int",      "length": 6,  "is_pk": true,  "is_fk": false, "references": null },
      { "column_number": 3,  "field": "StaCode",    "business_name": "GST / Tax Code",              "description": "Tax code applied (e.g. GST18, IGST18, CGST9, SGST9). FK to OSTC.",           "type": "nVarChar", "length": 8,  "is_pk": false, "is_fk": true,  "references": {"table":"OSTC","business_name":"Sales Tax Code","column":"Code","confidence":0.92} },
      { "column_number": 4,  "field": "TaxRate",    "business_name": "GST Rate (%)",                "description": "Tax rate applied (e.g. 18, 12, 5, 0 for exempt).",                            "type": "Rate",     "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 5,  "field": "TaxSum",     "business_name": "Total GST Amount (INR)",      "description": "Total GST collected on this invoice for this tax code.",                      "type": "Sum",      "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 6,  "field": "TaxSumSy",   "business_name": "GST Amount in System Currency","description": "GST in system base currency (for FC transactions).",                         "type": "Sum",      "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 7,  "field": "TaxSumFc",   "business_name": "GST Amount in Foreign Currency","description": "GST in document foreign currency.",                                        "type": "Sum",      "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 8,  "field": "TaxbleAmnt", "business_name": "Taxable Base Amount",         "description": "Amount on which GST is calculated.",                                         "type": "Sum",      "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 9,  "field": "CalcBy",     "business_name": "Tax Calculated By",           "description": "How the tax was computed (on gross or net amount).",                         "type": "Char",     "length": 1,  "is_pk": false, "is_fk": false, "references": null, "enum_values": {"N":"Net Amount","G":"Gross Amount"} }
    ]
  },
  {
    "table_name": "PCH4",
    "business_name": "A/P Invoice Tax Lines (Input GST Breakdown per Purchase Invoice)",
    "module": "Purchasing",
    "module_id": 4,
    "description": "Stores detailed input GST breakdown for each purchase invoice — CGST, SGST, IGST, CESS amounts per tax code. Essential for GSTR-2A reconciliation and input tax credit (ITC) reports.",
