      { "to_table": "OSTC", "to_business_name": "Sales Tax Code", "from_column": "StaCode",  "to_column": "Code",     "on_clause": "PCH4.StaCode = OSTC.Code",     "join_type": "LEFT", "purpose": "Get GST code name and rate for input tax credit analysis", "confidence": 0.92 }
    ],
    "columns": [
      { "column_number": 1, "field": "DocEntry",   "business_name": "A/P Invoice Internal ID",        "description": "FK to OPCH.DocEntry. Composite PK with LineNum.",              "type": "Int",      "length": 11, "is_pk": true,  "is_fk": true,  "references": {"table":"OPCH","business_name":"A/P Invoice","column":"DocEntry","confidence":0.99} },
      { "column_number": 2, "field": "LineNum",    "business_name": "Tax Line Number",                "description": "Sequential line for each GST component.",                      "type": "Int",      "length": 6,  "is_pk": true,  "is_fk": false, "references": null },
      { "column_number": 3, "field": "StaCode",    "business_name": "Input GST / Tax Code",           "description": "GST code (e.g. CGST9, SGST9, IGST18). FK to OSTC.",           "type": "nVarChar", "length": 8,  "is_pk": false, "is_fk": true,  "references": {"table":"OSTC","business_name":"Sales Tax Code","column":"Code","confidence":0.92} },
      { "column_number": 4, "field": "TaxRate",    "business_name": "Input GST Rate (%)",             "description": "GST rate on the purchase (e.g. 18, 12, 5).",                   "type": "Rate",     "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 5, "field": "TaxSum",     "business_name": "Input GST Amount (ITC)",         "description": "Total input GST claimable on this purchase invoice.",          "type": "Sum",      "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 6, "field": "TaxSumSy",   "business_name": "Input GST in System Currency",   "description": "Input GST in system base currency.",                           "type": "Sum",      "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 7, "field": "TaxbleAmnt", "business_name": "Taxable Purchase Base Amount",   "description": "Purchase amount on which GST is calculated.",                 "type": "Sum",      "length": 19, "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 8, "field": "CalcBy",     "business_name": "Tax Calculated By",              "description": "Whether tax computed on net or gross.",                        "type": "Char",     "length": 1,  "is_pk": false, "is_fk": false, "references": null, "enum_values": {"N":"Net Amount","G":"Gross Amount"} }
    ]
  },
  {
    "table_name": "OSTC",
    "business_name": "Sales Tax Code Master (GST Code Definition)",
    "module": "Finance",
    "module_id": 5,
    "description": "Defines all tax codes used in the system — GST rates, VAT codes, TDS codes. Each document line references a VatGroup/StaCode which maps here. Master for GST rate configuration.",
    "is_master": true, "is_header": false, "is_line": false,
    "total_columns": 15,
    "primary_key": { "columns": ["Code"], "confidence": 0.99, "rule": "known_master_pk" },
    "joins": [
      { "to_table": "INV4", "to_business_name": "A/R Invoice Tax Lines", "from_column": "Code", "to_column": "StaCode", "on_clause": "OSTC.Code = INV4.StaCode", "join_type": "LEFT", "purpose": "Get all AR invoices using this tax code",              "confidence": 0.92 },
      { "to_table": "PCH4", "to_business_name": "A/P Invoice Tax Lines", "from_column": "Code", "to_column": "StaCode", "on_clause": "OSTC.Code = PCH4.StaCode", "join_type": "LEFT", "purpose": "Get all AP invoices with this input tax code",         "confidence": 0.92 }
    ],
    "columns": [
      { "column_number": 1,  "field": "Code",       "business_name": "Tax Code",                  "description": "Unique GST/tax code (e.g. GST18, CGST9, IGST18, EXEMPT). PK.",    "type": "nVarChar", "length": 8,  "is_pk": true,  "is_fk": false, "references": null },
      { "column_number": 2,  "field": "Name",       "business_name": "Tax Code Description",      "description": "Full name of the tax code (e.g. GST 18%, IGST 18%, Exempt).",      "type": "nVarChar", "length": 100,"is_pk": false, "is_fk": false, "references": null },
      { "column_number": 3,  "field": "Rate",       "business_name": "Tax Rate (%)",              "description": "Percentage rate for this tax code.",                               "type": "Rate",     "length": 0,  "is_pk": false, "is_fk": false, "references": null },
      { "column_number": 4,  "field": "Category",   "business_name": "Tax Category",             "description": "Type of tax this code represents.",                                "type": "Char",     "length": 1,  "is_pk": false, "is_fk": false, "references": null, "enum_values": {"O":"Output (Sales)","I":"Input (Purchase)","E":"Exempt","Z":"Zero-rated"} },
      { "column_number": 5,  "field": "IsItemLevel","business_name": "Applied at Item Level",     "description": "Y if tax is applied per line item, N if at document header level.", "type": "Char",    "length": 1,  "is_pk": false, "is_fk": false, "references": null, "enum_values": {"Y":"Line-level","N":"Header-level"} },
      { "column_number": 6,  "field": "Account",    "business_name": "Tax GL Account",           "description": "GL account where this tax is posted. FK to OACT.",                 "type": "nVarChar", "length": 15, "is_pk": false, "is_fk": true,  "references": {"table":"OACT","business_name":"Chart of Accounts","column":"AcctCode","confidence":0.88} },
      { "column_number": 7,  "field": "Inactive",   "business_name": "Is Inactive",              "description": "Y if this tax code is no longer in use.",                          "type": "Char",     "length": 1,  "is_pk": false, "is_fk": false, "references": null, "enum_values": {"Y":"Inactive","N":"Active"} }
    ]
  },
  {
